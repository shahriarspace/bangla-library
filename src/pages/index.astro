---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const base = import.meta.env.BASE_URL;

// Group by category
const byCategory = books.reduce((acc, book) => {
  const cat = book.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(book);
  return acc;
}, {} as Record<string, typeof books>);
---
<Base title="Home">
  <main>
    <!-- Hero -->
    <section style="padding: 80px 24px 60px; text-align: center; border-bottom: 1px solid var(--border); position: relative; overflow: hidden;">
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse at center top, rgba(200,160,80,0.06) 0%, transparent 70%);pointer-events:none;"></div>
      <div style="font-size:0.7rem;letter-spacing:0.35em;color:var(--gold);text-transform:uppercase;margin-bottom:20px;opacity:0.8;">
        Free · Bilingual · Classical
      </div>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);color:var(--gold-light);font-weight:400;margin-bottom:12px;line-height:1.2;">
        বাংলা পাঠাগার
      </h1>
      <h2 style="font-size:clamp(1rem,2.5vw,1.5rem);color:var(--gold);font-weight:400;margin-bottom:24px;letter-spacing:0.1em;">
        Bangla Library
      </h2>
      <p style="max-width:540px;margin:0 auto 40px;color:var(--text-dim);font-size:1rem;line-height:1.8;">
        Classical Bengali literature with parallel English translations. Read the original Bangla alongside its English rendering, side by side.
      </p>
      <!-- Search box (powered by Pagefind after build) -->
      <div id="search" style="margin-bottom:40px;"></div>
      <script>
        window.addEventListener('DOMContentLoaded', () => {
          if (window.PagefindUI) {
            new window.PagefindUI({ element: '#search', showImages: false });
          }
        });
      </script>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href={`${base}/books`} style="padding:12px 28px;border:1px solid var(--gold);color:var(--gold-light);font-size:0.9rem;letter-spacing:0.08em;transition:all 0.2s;" onmouseover="this.style.background='rgba(200,160,80,0.1)'" onmouseout="this.style.background='transparent'">
          Browse All Books
        </a>
        <a href={`${base}/authors`} style="padding:12px 28px;border:1px solid var(--border);color:var(--gold-dim);font-size:0.9rem;letter-spacing:0.08em;transition:all 0.2s;" onmouseover="this.style.background='rgba(200,160,80,0.05)'" onmouseout="this.style.background='transparent'">
          By Author
        </a>
      </div>
    </section>

    <!-- Stats bar -->
    <section style="border-bottom:1px solid var(--border);padding:24px;">
      <div class="container" style="display:flex;gap:40px;justify-content:center;flex-wrap:wrap;">
        {[
          ['বই', 'Books', books.length],
          ['লেখক', 'Authors', [...new Set(books.map(b => b.data.author_en))].length],
          ['বিভাগ', 'Categories', Object.keys(byCategory).length],
        ].map(([bn, en, count]) => (
          <div style="text-align:center;">
            <div style="font-size:1.8rem;color:var(--gold-light);font-weight:600;">{count}</div>
            <div style="font-size:0.7rem;letter-spacing:0.15em;color:var(--gold-dim);text-transform:uppercase;">{en} · {bn}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Books by category -->
    <section style="padding:60px 24px;">
      <div class="container">
        {Object.entries(byCategory).map(([category, catBooks]) => (
          <div style="margin-bottom:56px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
              <h2 style="font-size:0.75rem;letter-spacing:0.25em;color:var(--gold);text-transform:uppercase;font-weight:400;">{category}</h2>
              <div style="flex:1;height:1px;background:var(--border);"></div>
            </div>
            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
              {catBooks.map(book => (
                <a href={`${base}/books/${book.id}`} style="display:block;padding:24px;border:1px solid var(--border);background:rgba(255,255,255,0.02);transition:all 0.25s;text-decoration:none;" onmouseover="this.style.borderColor='rgba(200,160,80,0.4)';this.style.background='rgba(200,160,80,0.04)'" onmouseout="this.style.borderColor='rgba(200,160,80,0.15)';this.style.background='rgba(255,255,255,0.02)'">
                  <div style="font-size:1.3rem;font-family:var(--font-bn);color:var(--gold-light);margin-bottom:4px;">{book.data.title_bn}</div>
                  <div style="font-size:0.9rem;color:var(--gold);margin-bottom:12px;font-style:italic;">{book.data.title_en}</div>
                  <div style="font-size:0.78rem;color:var(--text-dim);">
                    {book.data.author_en} · {book.data.year}
                  </div>
                  {book.data.description_en && (
                    <div style="font-size:0.8rem;color:var(--text-dim);margin-top:10px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                      {book.data.description_en}
                    </div>
                  )}
                  <div style="margin-top:14px;font-size:0.72rem;letter-spacing:0.1em;color:var(--gold-dim);">
                    {book.data.paragraphs.length} passages · Read →
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Base>
