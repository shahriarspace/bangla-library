---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import FeaturedSection from '../components/FeaturedSection.jsx';
import FallbackCover from '../components/FallbackCover.jsx';

const allBooks = await getCollection('books', ({ data }) => data.status === 'published');
const base = import.meta.env.BASE_URL;

// Load analytics & coming soon data (graceful fallback)
let reads = { reads: {}, likes: {} };
let comingSoonData = [];
try { reads = await import('../../data/analytics/reads.json'); } catch {}
try { comingSoonData = (await import('../../data/coming-soon.json')).default; } catch {}

// Recently added — sort by published_date descending
const recentBooks = [...allBooks]
  .sort((a, b) => (b.data.published_date || '').localeCompare(a.data.published_date || ''))
  .slice(0, 6)
  .map(b => ({ slug: b.id, ...b.data }));

// Top read — sort by reads.json counts
const readCounts = reads.reads || reads.default?.reads || {};
const topRead = [...allBooks]
  .sort((a, b) => (readCounts[b.id] || 0) - (readCounts[a.id] || 0))
  .slice(0, 6)
  .map(b => ({ slug: b.id, ...b.data, reads: readCounts[b.id] || 0 }));

// Slideshow — combine top read + recent, deduplicate
const slideshowBooks = [...topRead, ...recentBooks]
  .filter((b, i, arr) => arr.findIndex(x => x.slug === b.slug) === i)
  .slice(0, 8);

// Group by category
const byCategory = allBooks.reduce((acc, book) => {
  const cat = book.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(book);
  return acc;
}, {} as Record<string, typeof allBooks>);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Bangla Library",
  "alternateName": "বাংলা পাঠাগার",
  "url": "https://shahriarspace.github.io/bangla-library/",
  "description": "A free bilingual digital library of classical Bangla literature with side-by-side English translations.",
  "inLanguage": ["en", "bn"],
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://shahriarspace.github.io/bangla-library/books/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---
<Base
  title="Home"
  description="Bangla Library: Read classical Bengali literature with parallel English translations. Free bilingual digital library featuring Rabindranath Tagore, Bankim Chandra, Humayun Ahmed, and more."
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <main>
    <!-- Hero -->
    <section class="hero-section">
      <div class="hero-glow"></div>
      <div style="font-size:0.7rem;letter-spacing:0.35em;color:var(--gold);text-transform:uppercase;margin-bottom:20px;opacity:0.8;">
        Free · Bilingual · Classical
      </div>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);color:var(--gold-light);font-weight:400;margin-bottom:12px;line-height:1.2;" lang="bn">
        বাংলা পাঠাগার
      </h1>
      <h2 style="font-size:clamp(1rem,2.5vw,1.5rem);color:var(--gold);font-weight:400;margin-bottom:24px;letter-spacing:0.1em;">
        Bangla Library
      </h2>
      <p style="max-width:540px;margin:0 auto 40px;color:var(--text-dim);font-size:1rem;line-height:1.8;">
        Classical Bengali literature with parallel English translations. Read the original Bangla alongside its English rendering, side by side.
      </p>
      <!-- Search box (powered by Pagefind after build) -->
      <div id="search" style="margin-bottom:40px;"></div>
      <script>
        window.addEventListener('DOMContentLoaded', () => {
          if (window.PagefindUI) {
            new window.PagefindUI({ element: '#search', showImages: false });
          }
        });
      </script>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href={`${base}/books`} class="hero-btn hero-btn-primary">
          Browse All Books
        </a>
        <a href={`${base}/authors`} class="hero-btn hero-btn-secondary">
          By Author
        </a>
      </div>
    </section>

    <!-- Featured Section -->
    <FeaturedSection
      client:load
      recentBooks={recentBooks}
      comingSoon={comingSoonData}
      topRead={topRead}
      slideshowBooks={slideshowBooks}
      basePath={base}
    />

    <!-- Stats bar -->
    <section class="stats-section">
      <div class="container" style="display:flex;gap:40px;justify-content:center;flex-wrap:wrap;">
        {[
          ['বই', 'Books', allBooks.length],
          ['লেখক', 'Authors', [...new Set(allBooks.map(b => b.data.author_en))].length],
          ['বিভাগ', 'Categories', Object.keys(byCategory).length],
        ].map(([bn, en, count]) => (
          <div style="text-align:center;">
            <div style="font-size:1.8rem;color:var(--gold-light);font-weight:600;">{count}</div>
            <div style="font-size:0.7rem;letter-spacing:0.15em;color:var(--gold-dim);text-transform:uppercase;">{en} · {bn}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Books by category -->
    <section class="books-section">
      <div class="container">
        {Object.entries(byCategory).map(([category, catBooks]) => (
          <div style="margin-bottom:56px;">
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">
              <h2 style="font-size:0.75rem;letter-spacing:0.25em;color:var(--gold);text-transform:uppercase;font-weight:400;white-space:nowrap;">{category}</h2>
              <div style="flex:1;height:1px;background:var(--border);"></div>
            </div>
            <div class="book-grid">
              {catBooks.map(book => (
                <a href={`${base}/books/${book.id}`} class="book-card">
                  <div class="card-cover">
                    {book.data.cover_image ? (
                      <img src={book.data.cover_image} alt={`Cover of ${book.data.title_en}`} class="card-cover-img" loading="lazy" />
                    ) : (
                      <FallbackCover title_bn={book.data.title_bn} title_en={book.data.title_en} author_en={book.data.author_en} year={book.data.year} />
                    )}
                  </div>
                  <div style="font-size:1.3rem;font-family:var(--font-bn);color:var(--gold-light);margin-bottom:4px;">{book.data.title_bn}</div>
                  <div style="font-size:0.9rem;color:var(--gold);margin-bottom:12px;font-style:italic;">{book.data.title_en}</div>
                  <div style="font-size:0.78rem;color:var(--text-dim);">
                    {book.data.author_en} · {book.data.year}
                  </div>
                  {book.data.description_en && (
                    <div style="font-size:0.8rem;color:var(--text-dim);margin-top:10px;line-height:1.6;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                      {book.data.description_en}
                    </div>
                  )}
                  <div style="margin-top:14px;font-size:0.72rem;letter-spacing:0.1em;color:var(--gold-dim);">
                    {book.data.paragraphs.length} passages · Read &rarr;
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  </main>
</Base>

<style>
  .hero-section {
    padding: 80px 24px 60px;
    text-align: center;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, var(--card-hover-bg) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-btn {
    padding: 12px 28px;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    transition: all 0.2s;
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .hero-btn-primary {
    border: 1px solid var(--gold);
    color: var(--gold-light);
  }
  .hero-btn-primary:hover {
    background: var(--btn-active-bg);
  }
  .hero-btn-secondary {
    border: 1px solid var(--border);
    color: var(--gold-dim);
  }
  .hero-btn-secondary:hover {
    background: var(--card-hover-bg);
  }
  .stats-section {
    border-bottom: 1px solid var(--border);
    padding: 24px;
  }
  .books-section {
    padding: 60px 24px;
  }
  .book-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
    gap: 16px;
  }
  .book-card {
    display: block;
    padding: 24px;
    border: 1px solid var(--border);
    background: var(--bg-panel);
    transition: all 0.25s;
    text-decoration: none;
  }
  .card-cover {
    width: 100%;
    height: 200px;
    margin-bottom: 16px;
    overflow: hidden;
    border: 1px solid rgba(200,160,80,0.15);
  }
  .card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .book-card:hover {
    border-color: var(--card-hover-border) !important;
    background: var(--card-hover-bg) !important;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 48px 16px 40px;
    }
    .books-section {
      padding: 40px 16px;
    }
    .stats-section {
      padding: 20px 16px;
    }
  }
  @media (max-width: 480px) {
    .hero-section {
      padding: 36px 16px 32px;
    }
    .books-section {
      padding: 32px 12px;
    }
    .book-card {
      padding: 18px;
    }
  }
</style>
