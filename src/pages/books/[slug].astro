---
import Base from '../../layouts/Base.astro';
import BilingualReader from '../../components/BilingualReader.jsx';
import LikeButton from '../../components/LikeButton.jsx';
import Giscus from '../../components/Giscus.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({ params: { slug: book.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('books', slug);
const book = entry.data;
const base = import.meta.env.BASE_URL;

const bookDescription = book.description_en
  || `Read ${book.title_en} by ${book.author_en} in Bangla and English — side-by-side bilingual reading with ${book.paragraphs.length} passages.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": book.title_en,
    "alternateName": book.title_bn,
    "author": {
      "@type": "Person",
      "name": book.author_en,
      "alternateName": book.author_bn,
    },
    "datePublished": book.year,
    "inLanguage": ["bn", "en"],
    "genre": book.category,
    "description": bookDescription,
    "url": `https://shahriarspace.github.io/bangla-library/books/${slug}/`,
    "isAccessibleForFree": true,
    "publisher": {
      "@type": "Organization",
      "name": "Bangla Library",
    },
    "numberOfPages": Math.ceil(book.paragraphs.length / 12),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://shahriarspace.github.io/bangla-library/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Books",
        "item": "https://shahriarspace.github.io/bangla-library/books/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": book.title_en,
        "item": `https://shahriarspace.github.io/bangla-library/books/${slug}/`
      }
    ]
  }
];
---

<Base
  title={`${book.title_en} by ${book.author_en}`}
  description={bookDescription}
  ogType="book"
  canonicalPath={`/books/${slug}/`}
  jsonLd={jsonLd}
>
  <main>

    <!-- Book header -->
    <section class="book-header">
      <div class="book-header-glow"></div>
      <div style="font-size:0.68rem;letter-spacing:0.2em;color:var(--gold-dim);text-transform:uppercase;margin-bottom:16px;">
        <a href={`${base}/books`} style="color:var(--gold-dim);">Library</a>
        <span style="margin:0 8px;opacity:0.4;">&middot;</span>
        {book.category}
      </div>
      <h1 style="font-family:var(--font-bn);font-size:clamp(1.8rem,4vw,3rem);color:var(--gold-light);font-weight:600;margin-bottom:8px;" lang="bn">
        {book.title_bn}
      </h1>
      <h2 style="font-size:clamp(1rem,2vw,1.4rem);color:var(--gold);font-weight:400;font-style:italic;margin-bottom:20px;">
        {book.title_en}
      </h2>
      <div style="font-size:0.85rem;color:var(--text-dim);margin-bottom:8px;">
        <a href={`${base}/authors/${encodeURIComponent(book.author_en.toLowerCase().replace(/ /g,'-'))}`} style="color:var(--gold-dim);">
          {book.author_bn} &middot; {book.author_en}
        </a>
        <span style="margin:0 10px;opacity:0.3;">&middot;</span>
        {book.year}
      </div>
      <!-- Like / Heart button (Giscus reactions) -->
      <div style="margin-top:16px;">
        <LikeButton client:idle />
      </div>
      {book.description_en && (
        <p style="max-width:600px;margin:20px auto 0;font-size:0.88rem;color:var(--text-dim);line-height:1.8;">
          {book.description_en}
        </p>
      )}
      <div style="width:40px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:28px auto 0;"></div>
    </section>

    {/* Copyright warning banner */}
    {book.copyright_notice && (
      <div class="copyright-banner" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:1px;">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span>{book.copyright_notice}</span>
      </div>
    )}

    <!-- SEO-visible text (visually hidden but crawlable by search engines) -->
    <div class="sr-only" data-pagefind-body>
      <h2>{book.title_en} - {book.title_bn} by {book.author_en}</h2>
      {book.paragraphs.map(p => (
        <div>
          <p lang="bn">{p.bn}</p>
          <p lang="en">{p.en}</p>
        </div>
      ))}
    </div>

    <!-- Bilingual Reader (React Island) -->
    <section class="reader-section">
      <div class="container">
        <BilingualReader client:load book={book} base={base} />
      </div>
    </section>

    <!-- Comments & Reactions (Giscus) -->
    <Giscus term={`book/${slug}`} />

    <!-- Related / nav -->
    <section style="padding: 0 24px 60px;">
      <div class="container" style="text-align:center;">
        <a href={`${base}/books`} class="back-link">
          &larr; Back to Library
        </a>
      </div>
    </section>

  </main>
</Base>

<style>
  .book-header {
    padding: 56px 24px 40px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .book-header-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, var(--card-hover-bg) 0%, transparent 65%);
    pointer-events: none;
  }
  .back-link {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--gold-dim);
    text-transform: uppercase;
    padding: 12px 16px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .copyright-banner {
    max-width: 680px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.8rem;
    line-height: 1.6;
    color: #c87a3a;
    background: rgba(200, 122, 58, 0.08);
    border: 1px solid rgba(200, 122, 58, 0.2);
    border-radius: 4px;
    margin-top: 20px;
  }
  .reader-section {
    padding: 40px 24px 60px;
    overflow-x: hidden;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .book-header {
      padding: 36px 16px 28px;
    }
    .reader-section {
      padding: 28px 12px 40px;
    }
  }
  @media (max-width: 480px) {
    .book-header {
      padding: 28px 12px 24px;
    }
    .reader-section {
      padding: 20px 8px 32px;
    }
  }
</style>

<!-- LikeButton styles (global so they reach the React island) -->
<style is:global>
  .like-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 24px;
    border: 1px solid var(--border);
    background: var(--bg-panel);
    color: var(--gold-dim);
    font-family: var(--font-en);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.25s ease;
    letter-spacing: 0.03em;
    position: relative;
    z-index: 1;
  }
  .like-button:hover {
    border-color: var(--border-active);
    color: var(--gold);
    background: var(--btn-active-bg);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
  }
  .like-button:active {
    transform: translateY(0);
  }
  .like-button__heart {
    transition: transform 0.25s ease, color 0.25s ease;
  }
  .like-button:hover .like-button__heart {
    color: #e25555;
    fill: rgba(226, 85, 85, 0.15);
  }
  .like-button__count {
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    min-width: 1ch;
  }
  /* Pulse animation */
  .like-button--pulse .like-button__heart {
    animation: like-pulse 0.6s ease;
    color: #e25555;
    fill: rgba(226, 85, 85, 0.25);
  }
  @keyframes like-pulse {
    0% { transform: scale(1); }
    25% { transform: scale(1.35); }
    50% { transform: scale(0.95); }
    75% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }
  @media (max-width: 768px) {
    .like-button {
      padding: 10px 20px;
      min-height: 44px;
    }
  }
</style>
