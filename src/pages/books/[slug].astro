---
import Base from '../../layouts/Base.astro';
import BilingualReader from '../../components/BilingualReader.jsx';
import InteractionIsland from '../../components/InteractionIsland.jsx';
import ReadCounter from '../../components/ReadCounter.jsx';
import ShareButtons from '../../components/ShareButtons.jsx';
import FallbackCover from '../../components/FallbackCover.jsx';
import { WORKER_URL } from '../../site-config.js';
import { getCollection, getEntry } from 'astro:content';
import readsJson from '../../../data/analytics/reads.json';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({ params: { slug: book.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('books', slug);
const book = entry.data;
const base = import.meta.env.BASE_URL;

// Read counts from analytics data
const initialReads = (readsJson.reads && readsJson.reads[slug]) || 0;
const initialLikes = (readsJson.likes && readsJson.likes[slug]) || 0;

const bookDescription = book.description_en
  || `Read ${book.title_en} by ${book.author_en} in Bangla and English — side-by-side bilingual reading with ${book.paragraphs.length} passages.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": book.title_en,
    "alternateName": book.title_bn,
    "author": {
      "@type": "Person",
      "name": book.author_en,
      "alternateName": book.author_bn,
    },
    "datePublished": book.year,
    "inLanguage": ["bn", "en"],
    "genre": book.category,
    "description": bookDescription,
    ...(book.cover_image && { "image": book.cover_image.startsWith('http') ? book.cover_image : `https://shahriarspace.github.io/bangla-library${book.cover_image}` }),
    "url": `https://shahriarspace.github.io/bangla-library/books/${slug}/`,
    "isAccessibleForFree": true,
    "publisher": {
      "@type": "Organization",
      "name": "Bangla Library",
    },
    "numberOfPages": Math.ceil(book.paragraphs.length / 12),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://shahriarspace.github.io/bangla-library/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Books",
        "item": "https://shahriarspace.github.io/bangla-library/books/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": book.title_en,
        "item": `https://shahriarspace.github.io/bangla-library/books/${slug}/`
      }
    ]
  }
];
---

<Base
  title={`${book.title_en} by ${book.author_en}`}
  description={bookDescription}
  ogType="book"
  canonicalPath={`/books/${slug}/`}
  jsonLd={jsonLd}
>
  <main>

    <!-- Book header -->
    <section class="book-header">
      <div class="book-header-glow"></div>

      <div class="book-header-layout">
        <!-- Book cover (left) -->
        <div class="book-cover-wrapper">
          {book.cover_image ? (
            <img
              src={book.cover_image}
              alt={`Cover of ${book.title_en}`}
              class="book-cover-img"
              loading="eager"
            />
          ) : (
            <div class="book-cover-fallback">
              <FallbackCover
                title_bn={book.title_bn}
                title_en={book.title_en}
                author_en={book.author_en}
                year={book.year}
              />
            </div>
          )}
        </div>

        <!-- Book metadata (middle) -->
        <div class="book-meta">
          <div style="font-size:0.68rem;letter-spacing:0.2em;color:var(--gold-dim);text-transform:uppercase;margin-bottom:16px;">
            <a href={`${base}/books`} style="color:var(--gold-dim);">Library</a>
            <span style="margin:0 8px;opacity:0.4;">&middot;</span>
            {book.category}
          </div>
          <h1 style="font-family:var(--font-bn);font-size:clamp(1.8rem,4vw,3rem);color:var(--gold-light);font-weight:600;margin-bottom:8px;" lang="bn">
            {book.title_bn}
          </h1>
          <h2 style="font-size:clamp(1rem,2vw,1.4rem);color:var(--gold);font-weight:400;font-style:italic;margin-bottom:20px;">
            {book.title_en}
          </h2>
          <div style="font-size:0.85rem;color:var(--text-dim);margin-bottom:8px;">
            <a href={`${base}/authors/${encodeURIComponent(book.author_en.toLowerCase().replace(/ /g,'-'))}`} style="color:var(--gold-dim);">
              {book.author_bn} &middot; {book.author_en}
            </a>
            <span style="margin:0 10px;opacity:0.3;">&middot;</span>
            {book.year}
          </div>
          {book.description_en && (
            <p style="font-size:0.88rem;color:var(--text-dim);line-height:1.8;margin-top:16px;">
              {book.description_en}
            </p>
          )}
          <!-- Share buttons -->
          <div style="margin-top:24px;">
            <ShareButtons
              client:load
              bookTitle={book.title_en}
              bookTitleBn={book.title_bn}
              authorEn={book.author_en}
              slug={slug}
              siteUrl="https://shahriarspace.github.io/bangla-library"
            />
          </div>
        </div>

        {/* Did You Know? — third column */}
        {book.fun_facts && book.fun_facts.length > 0 && (
          <div class="book-facts">
            <h3 class="fun-facts-heading">Did You Know?</h3>
            <div class="fun-facts-list">
              {book.fun_facts.map((fact) => (
                <div class={`fun-fact-card fun-fact-${fact.type}`}>
                  <div class="fun-fact-icon" aria-hidden="true">
                    {fact.type === 'film' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line><line x1="17" y1="17" x2="22" y2="17"></line></svg>
                    )}
                    {fact.type === 'award' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                    )}
                    {fact.type === 'cultural' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                    )}
                    {fact.type === 'history' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    )}
                    {fact.type === 'translation' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V14a2 2 0 0 1 2-2h4"></path><path d="m5 15 4-8 4 8"></path><line x1="6" y1="13" x2="12" y2="13"></line><path d="M14 7h6"></path><path d="M17 4v6"></path><path d="m14 18 3-3 3 3"></path></svg>
                    )}
                    {fact.type === 'music' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
                    )}
                    {fact.type === 'publication' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                    )}
                    {fact.type === 'influence' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    )}
                    {fact.type === 'controversy' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                    )}
                    {fact.type === 'general' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                    )}
                  </div>
                  <div class="fun-fact-content">
                    <span class="fun-fact-tag">{
                      fact.type === 'film' ? 'Film Adaptation' :
                      fact.type === 'award' ? 'Award' :
                      fact.type === 'cultural' ? 'Cultural Impact' :
                      fact.type === 'history' ? 'Historical' :
                      fact.type === 'translation' ? 'Translation' :
                      fact.type === 'music' ? 'Music' :
                      fact.type === 'publication' ? 'Publication' :
                      fact.type === 'influence' ? 'Influence' :
                      fact.type === 'controversy' ? 'Controversy' :
                      'Fun Fact'
                    }</span>
                    <p class="fun-fact-text">{fact.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <div style="width:40px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:28px auto 0;"></div>
    </section>

    {/* Copyright warning banner */}
    {book.copyright_notice && (
      <div class="copyright-banner" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:1px;">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span>{book.copyright_notice}</span>
      </div>
    )}

    <!-- SEO-visible text (visually hidden but crawlable by search engines & Pagefind) -->
    <div class="sr-only" data-pagefind-body>
      <h2 data-pagefind-meta="title">{book.title_en} - {book.title_bn} by {book.author_en}</h2>
      <p data-pagefind-meta="author">{book.author_en} ({book.author_bn})</p>
      <p data-pagefind-meta="category">{book.category}</p>
      {book.paragraphs.map((p, i) => (
        <div data-pagefind-weight={i === 0 ? "5" : "1"}>
          <p lang="bn">{p.bn}</p>
          <p lang="en">{p.en}</p>
        </div>
      ))}
    </div>

    {/* Did You Know? — fun facts section */}

    <!-- Bilingual Reader (React Island) -->
    <section class="reader-section">
      <div class="container">
        <BilingualReader client:load book={book} base={base} workerUrl={WORKER_URL} />
        <!-- ReadCounter sentinel: observes reader visibility, fires after 30s -->
        <ReadCounter client:load slug={slug} initialCount={initialReads} workerUrl={WORKER_URL} />
      </div>
    </section>

    <!-- Interaction Island: Likes + Comments + Giscus (React Island) -->
    <InteractionIsland
      client:load
      slug={slug}
      bookTitle={book.title_en}
      initialLikes={initialLikes}
      initialReads={initialReads}
      workerUrl={WORKER_URL}
    />

    <!-- Related / nav -->
    <section style="padding: 0 24px 60px;">
      <div class="container" style="text-align:center;">
        <a href={`${base}/books`} class="back-link">
          &larr; Back to Library
        </a>
      </div>
    </section>

  </main>
</Base>

<style>
  .book-header {
    padding: 56px 24px 40px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    position: relative;
    overflow: visible;
  }
  .book-header-layout {
    display: flex;
    align-items: flex-start;
    gap: 28px;
    max-width: 980px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 1;
  }
  .book-cover-wrapper {
    width: 200px;
    min-width: 200px;
    height: 290px;
    flex-shrink: 0;
  }
  .book-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid rgba(200,160,80,0.3);
    border-radius: 3px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.2);
  }
  .book-cover-fallback {
    width: 100%;
    height: 100%;
  }
  .book-meta {
    flex: 1;
    min-width: 0;
  }
  .book-header-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, var(--card-hover-bg) 0%, transparent 65%);
    pointer-events: none;
    overflow: hidden;
  }
  .back-link {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--gold-dim);
    text-transform: uppercase;
    padding: 12px 16px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .copyright-banner {
    max-width: 680px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.8rem;
    line-height: 1.6;
    color: #c87a3a;
    background: rgba(200, 122, 58, 0.08);
    border: 1px solid rgba(200, 122, 58, 0.2);
    border-radius: 4px;
    margin-top: 20px;
  }
  .reader-section {
    padding: 40px 24px 60px;
    overflow-x: hidden;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .book-header {
      padding: 36px 16px 28px;
    }
    .book-header-layout {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
    }
    .book-cover-wrapper {
      width: 150px;
      min-width: 150px;
      height: 218px;
    }
    .book-facts {
      width: 100%;
      max-width: 100%;
      min-width: 0;
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--border, rgba(200, 160, 80, 0.1));
      padding-top: 20px;
      max-height: none;
      overflow-y: visible;
    }
    .fun-facts-heading {
      position: static;
      background: none;
    }
    .fun-facts-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }
    .reader-section {
      padding: 28px 12px 40px;
    }
  }
  @media (max-width: 480px) {
    .book-header {
      padding: 28px 12px 24px;
    }
    .book-cover-wrapper {
      width: 120px;
      min-width: 120px;
      height: 175px;
    }
    .fun-facts-list {
      grid-template-columns: 1fr;
    }
    .reader-section {
      padding: 20px 8px 32px;
    }
  }

  /* --- Did You Know? (third column) --- */
  .book-facts {
    width: 240px;
    min-width: 200px;
    max-width: 260px;
    flex-shrink: 0;
    align-self: stretch;
    border-left: 1px solid var(--border, rgba(200, 160, 80, 0.1));
    padding-left: 24px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(200, 160, 80, 0.2) transparent;
  }
  .book-facts::-webkit-scrollbar {
    width: 4px;
  }
  .book-facts::-webkit-scrollbar-track {
    background: transparent;
  }
  .book-facts::-webkit-scrollbar-thumb {
    background: rgba(200, 160, 80, 0.2);
    border-radius: 4px;
  }
  .fun-facts-heading {
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    position: sticky;
    top: 0;
    background: var(--bg, #1a1510);
    padding-bottom: 4px;
    z-index: 1;
  }
  .fun-facts-list {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .fun-fact-card {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 7px 9px;
    background: var(--card-bg, rgba(30, 25, 18, 0.6));
    border: 1px solid var(--border, rgba(200, 160, 80, 0.1));
    border-radius: 4px;
    transition: border-color 0.25s ease, background 0.25s ease;
  }
  .fun-fact-card:hover {
    border-color: rgba(200, 160, 80, 0.25);
    background: var(--card-hover-bg, rgba(40, 34, 24, 0.7));
  }
  .fun-fact-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(200, 160, 80, 0.08);
    color: var(--gold-dim, #b8a472);
  }
  .fun-fact-icon svg {
    width: 14px;
    height: 14px;
  }
  .fun-fact-content {
    flex: 1;
    min-width: 0;
  }
  .fun-fact-tag {
    display: inline-block;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold, #c8a050);
    background: rgba(200, 160, 80, 0.1);
    padding: 1px 5px;
    border-radius: 3px;
    margin-bottom: 3px;
  }
  /* category accent colors */
  .fun-fact-film .fun-fact-tag { color: #e0a0c0; background: rgba(224, 160, 192, 0.1); }
  .fun-fact-film .fun-fact-icon { color: #e0a0c0; background: rgba(224, 160, 192, 0.08); }
  .fun-fact-award .fun-fact-tag { color: #d4af37; background: rgba(212, 175, 55, 0.1); }
  .fun-fact-award .fun-fact-icon { color: #d4af37; background: rgba(212, 175, 55, 0.08); }
  .fun-fact-music .fun-fact-tag { color: #a0c8e0; background: rgba(160, 200, 224, 0.1); }
  .fun-fact-music .fun-fact-icon { color: #a0c8e0; background: rgba(160, 200, 224, 0.08); }
  .fun-fact-cultural .fun-fact-tag { color: #a0d8a0; background: rgba(160, 216, 160, 0.1); }
  .fun-fact-cultural .fun-fact-icon { color: #a0d8a0; background: rgba(160, 216, 160, 0.08); }
  .fun-fact-history .fun-fact-tag { color: #c8b090; background: rgba(200, 176, 144, 0.1); }
  .fun-fact-history .fun-fact-icon { color: #c8b090; background: rgba(200, 176, 144, 0.08); }
  .fun-fact-text {
    font-size: 0.73rem;
    color: var(--text-dim, #a89878);
    line-height: 1.5;
    margin: 0;
  }
</style>

