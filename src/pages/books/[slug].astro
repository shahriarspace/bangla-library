---
import Base from '../../layouts/Base.astro';
import BilingualReader from '../../components/BilingualReader.jsx';
import InteractionIsland from '../../components/InteractionIsland.jsx';
import ReadCounter from '../../components/ReadCounter.jsx';
import ShareButtons from '../../components/ShareButtons.jsx';
import FallbackCover from '../../components/FallbackCover.jsx';
import { WORKER_URL } from '../../site-config.js';
import { getCollection, getEntry } from 'astro:content';
import readsJson from '../../../data/analytics/reads.json';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({ params: { slug: book.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('books', slug);
const book = entry.data;
const base = import.meta.env.BASE_URL;

// Read counts from analytics data
const initialReads = (readsJson.reads && readsJson.reads[slug]) || 0;
const initialLikes = (readsJson.likes && readsJson.likes[slug]) || 0;

const bookDescription = book.description_en
  || `Read ${book.title_en} by ${book.author_en} in Bangla and English — side-by-side bilingual reading with ${book.paragraphs.length} passages.`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": book.title_en,
    "alternateName": book.title_bn,
    "author": {
      "@type": "Person",
      "name": book.author_en,
      "alternateName": book.author_bn,
    },
    "datePublished": book.year,
    "inLanguage": ["bn", "en"],
    "genre": book.category,
    "description": bookDescription,
    ...(book.cover_image && { "image": book.cover_image.startsWith('http') ? book.cover_image : `https://shahriarspace.github.io/bangla-library${book.cover_image}` }),
    "url": `https://shahriarspace.github.io/bangla-library/books/${slug}/`,
    "isAccessibleForFree": true,
    "publisher": {
      "@type": "Organization",
      "name": "Bangla Library",
    },
    "numberOfPages": Math.ceil(book.paragraphs.length / 12),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://shahriarspace.github.io/bangla-library/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Books",
        "item": "https://shahriarspace.github.io/bangla-library/books/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": book.title_en,
        "item": `https://shahriarspace.github.io/bangla-library/books/${slug}/`
      }
    ]
  }
];
---

<Base
  title={`${book.title_en} by ${book.author_en}`}
  description={bookDescription}
  ogType="book"
  canonicalPath={`/books/${slug}/`}
  jsonLd={jsonLd}
>
  <main>

    <!-- Book header -->
    <section class="book-header">
      <div class="book-header-glow"></div>

      <div class="book-header-layout">
        <!-- Book cover (left) -->
        <div class="book-cover-wrapper">
          {book.cover_image ? (
            <img
              src={book.cover_image}
              alt={`Cover of ${book.title_en}`}
              class="book-cover-img"
              loading="eager"
            />
          ) : (
            <div class="book-cover-fallback">
              <FallbackCover
                title_bn={book.title_bn}
                title_en={book.title_en}
                author_en={book.author_en}
                year={book.year}
              />
            </div>
          )}
        </div>

        <!-- Book metadata (right) -->
        <div class="book-meta">
          <div style="font-size:0.68rem;letter-spacing:0.2em;color:var(--gold-dim);text-transform:uppercase;margin-bottom:16px;">
            <a href={`${base}/books`} style="color:var(--gold-dim);">Library</a>
            <span style="margin:0 8px;opacity:0.4;">&middot;</span>
            {book.category}
          </div>
          <h1 style="font-family:var(--font-bn);font-size:clamp(1.8rem,4vw,3rem);color:var(--gold-light);font-weight:600;margin-bottom:8px;" lang="bn">
            {book.title_bn}
          </h1>
          <h2 style="font-size:clamp(1rem,2vw,1.4rem);color:var(--gold);font-weight:400;font-style:italic;margin-bottom:20px;">
            {book.title_en}
          </h2>
          <div style="font-size:0.85rem;color:var(--text-dim);margin-bottom:8px;">
            <a href={`${base}/authors/${encodeURIComponent(book.author_en.toLowerCase().replace(/ /g,'-'))}`} style="color:var(--gold-dim);">
              {book.author_bn} &middot; {book.author_en}
            </a>
            <span style="margin:0 10px;opacity:0.3;">&middot;</span>
            {book.year}
          </div>
          {book.description_en && (
            <p style="max-width:600px;font-size:0.88rem;color:var(--text-dim);line-height:1.8;margin-top:16px;">
              {book.description_en}
            </p>
          )}
          <!-- Share buttons -->
          <div style="margin-top:24px;">
            <ShareButtons
              client:load
              bookTitle={book.title_en}
              bookTitleBn={book.title_bn}
              authorEn={book.author_en}
              slug={slug}
              siteUrl="https://shahriarspace.github.io/bangla-library"
            />
          </div>
        </div>
      </div>

      <div style="width:40px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:28px auto 0;"></div>
    </section>

    {/* Copyright warning banner */}
    {book.copyright_notice && (
      <div class="copyright-banner" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:1px;">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span>{book.copyright_notice}</span>
      </div>
    )}

    <!-- SEO-visible text (visually hidden but crawlable by search engines & Pagefind) -->
    <div class="sr-only" data-pagefind-body>
      <h2 data-pagefind-meta="title">{book.title_en} - {book.title_bn} by {book.author_en}</h2>
      <p data-pagefind-meta="author">{book.author_en} ({book.author_bn})</p>
      <p data-pagefind-meta="category">{book.category}</p>
      {book.paragraphs.map((p, i) => (
        <div data-pagefind-weight={i === 0 ? "5" : "1"}>
          <p lang="bn">{p.bn}</p>
          <p lang="en">{p.en}</p>
        </div>
      ))}
    </div>

    <!-- Bilingual Reader (React Island) -->
    <section class="reader-section">
      <div class="container">
        <BilingualReader client:load book={book} base={base} workerUrl={WORKER_URL} />
        <!-- ReadCounter sentinel: observes reader visibility, fires after 30s -->
        <ReadCounter client:load slug={slug} initialCount={initialReads} workerUrl={WORKER_URL} />
      </div>
    </section>

    <!-- Interaction Island: Likes + Comments + Giscus (React Island) -->
    <InteractionIsland
      client:load
      slug={slug}
      bookTitle={book.title_en}
      initialLikes={initialLikes}
      initialReads={initialReads}
      workerUrl={WORKER_URL}
    />

    <!-- Related / nav -->
    <section style="padding: 0 24px 60px;">
      <div class="container" style="text-align:center;">
        <a href={`${base}/books`} class="back-link">
          &larr; Back to Library
        </a>
      </div>
    </section>

  </main>
</Base>

<style>
  .book-header {
    padding: 56px 24px 40px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .book-header-layout {
    display: flex;
    align-items: flex-start;
    gap: 40px;
    max-width: 760px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 1;
  }
  .book-cover-wrapper {
    width: 180px;
    min-width: 180px;
    height: 260px;
    flex-shrink: 0;
  }
  .book-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 1px solid rgba(200,160,80,0.3);
    box-shadow: 0 8px 32px rgba(0,0,0,0.4), 0 2px 8px rgba(0,0,0,0.2);
  }
  .book-cover-fallback {
    width: 100%;
    height: 100%;
  }
  .book-meta {
    flex: 1;
    min-width: 0;
  }
  .book-header-glow {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, var(--card-hover-bg) 0%, transparent 65%);
    pointer-events: none;
  }
  .back-link {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    color: var(--gold-dim);
    text-transform: uppercase;
    padding: 12px 16px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .copyright-banner {
    max-width: 680px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.8rem;
    line-height: 1.6;
    color: #c87a3a;
    background: rgba(200, 122, 58, 0.08);
    border: 1px solid rgba(200, 122, 58, 0.2);
    border-radius: 4px;
    margin-top: 20px;
  }
  .reader-section {
    padding: 40px 24px 60px;
    overflow-x: hidden;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 768px) {
    .book-header {
      padding: 36px 16px 28px;
    }
    .book-header-layout {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 24px;
    }
    .book-cover-wrapper {
      width: 140px;
      min-width: 140px;
      height: 200px;
    }
    .reader-section {
      padding: 28px 12px 40px;
    }
  }
  @media (max-width: 480px) {
    .book-header {
      padding: 28px 12px 24px;
    }
    .book-cover-wrapper {
      width: 120px;
      min-width: 120px;
      height: 175px;
    }
    .reader-section {
      padding: 20px 8px 32px;
    }
  }
</style>

